# Worklenz-only values. Never copy unrelated global credentials into this file.
EDITION=ce
NODE_ENV=production
PORT=3000
APP_ORIGIN=https://projects.myfusionadmin.com
FRONTEND_URL=https://projects.myfusionadmin.com
SERVER_CORS=https://projects.myfusionadmin.com
SOCKET_IO_CORS=https://projects.myfusionadmin.com
ALLOW_SIGNUPS=false

SESSION_NAME=worklenz.sid
SESSION_SECRET=generate-a-worklenz-only-secret
COOKIE_SECRET=generate-a-worklenz-only-secret
JWT_SECRET=generate-a-worklenz-only-secret
ENCRYPTION_KEY=generate-a-32-byte-hex-key
ENCRYPTION_SALT=generate-a-worklenz-only-salt

DB_HOST=postgres
DB_PORT=5432
DB_NAME=worklenz
DB_USER=worklenz
DB_PASSWORD=generate-a-worklenz-only-password
DB_MAX_CLIENTS=50
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=generate-a-worklenz-only-password

STORAGE_PROVIDER=s3
S3_ENDPOINT=https://cloudflare-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=worklenz-attachments-prod
S3_ACCESS_KEY_ID=dedicated-r2-attachment-access-key
S3_SECRET_ACCESS_KEY=dedicated-r2-attachment-secret-key
S3_FORCE_PATH_STYLE=false

SES_REGION=us-west-2
SES_ACCESS_KEY_ID=dedicated-ses-access-key
SES_SECRET_ACCESS_KEY=dedicated-ses-secret-key
EMAIL_FROM=Worklenz <noreply@myfusionadmin.com>
SES_WEBHOOKS_ENABLED=false
SES_SNS_TOPIC_ARN=arn:aws:sns:us-west-2:account:worklenz-ses-events

LOGIN_FAILURE_REDIRECT=https://projects.myfusionadmin.com/auth/authenticating
LOGIN_SUCCESS_REDIRECT=https://projects.myfusionadmin.com/auth/authenticating
GOOGLE_CALLBACK_URL=https://projects.myfusionadmin.com/secure/google/verify
ENABLE_EMAIL_CRONJOBS=true
ENABLE_RECURRING_JOBS=true
IMPORT_WORKER_ENABLED=true
USE_PG_NATIVE=false

VITE_EDITION=ce
VITE_API_URL=
VITE_SOCKET_URL=
VITE_ALLOW_SIGNUPS=false
VITE_ENABLE_GOOGLE_LOGIN=false
VITE_ENABLE_APPLE_LOGIN=false
SENTRY_UPLOAD_SOURCEMAPS=false

BACKUP_S3_ENDPOINT=https://cloudflare-account-id.r2.cloudflarestorage.com
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=worklenz-backups-prod
BACKUP_S3_ACCESS_KEY_ID=dedicated-r2-backup-access-key
BACKUP_S3_SECRET_ACCESS_KEY=dedicated-r2-backup-secret-key
BACKUP_AGE_RECIPIENT=age1-public-recipient
BACKUP_AGE_IDENTITY_FILE=/root/.config/worklenz/backup-age-key.txt
